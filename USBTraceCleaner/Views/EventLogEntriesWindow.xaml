<Window x:Class="USBTraceCleaner.Views.EventLogEntriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="События журнала"
        Width="960" Height="560"
        MinWidth="720" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="EventEntryCellText" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EventEntryCell" TargetType="DataGridCell" BasedOn="{StaticResource ResultsDataGridCell}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <CheckBox x:Name="ChkUsbOnly" Style="{StaticResource CompactCheckBox}"
                      Content="Только USB-похожие" IsChecked="False"
                      VerticalAlignment="Center" Margin="0,0,16,0"
                      Checked="Filter_Changed" Unchecked="Filter_Changed"/>
            <Button x:Name="BtnReload" Content="Обновить" Style="{StaticResource SecondaryButton}"
                    MinWidth="110" Margin="0,0,8,0" Click="BtnReload_Click"/>
            <Button Content="Закрыть" Style="{StaticResource PrimaryButton}"
                    MinWidth="110" IsDefault="True" IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="0"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="TxtTitle" Text="События" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="TxtSubtitle" Text="" Margin="0,4,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource MainCard}" MinHeight="180">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="0"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushModern}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <TextBlock x:Name="TxtCount" Text="Записей: 0" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                    <DataGrid x:Name="GridEvents" Grid.Row="1"
                              Style="{StaticResource ResultsDataGrid}"
                              CellStyle="{StaticResource EventEntryCell}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding DisplayTime}"
                                                Width="150" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventEntryCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Уровень" Binding="{Binding Level}"
                                                Width="100" MinWidth="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventEntryCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Код" Binding="{Binding Id}"
                                                Width="64" MinWidth="48">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventEntryCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Источник" Binding="{Binding Provider}"
                                                Width="180" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventEntryCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}"
                                                Width="320" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventEntryCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
