<Window x:Class="USBTraceCleaner.Views.NetworkSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сводка подключений"
        Width="760" Height="560"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Копировать" Style="{StaticResource SecondaryButton}"
                    MinWidth="110" Margin="0,0,8,0" Click="BtnCopy_Click"/>
            <Button Content="Закрыть" Style="{StaticResource PrimaryButton}"
                    MinWidth="110" IsDefault="True" Click="BtnClose_Click"/>
        </StackPanel>
        <Border Style="{StaticResource MainCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <StackPanel x:Name="SectionsPanel"/>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
