<UserControl x:Class="USBTraceCleaner.Views.NetworkAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Аудит сети" FontSize="28" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Полный анализ Wi‑Fi, Ethernet, VPN, DNS, реестра, журналов и роутера"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource MainCard}" Margin="0,0,0,12">
            <StackPanel Margin="14">
                <TextBlock Text="ПЕРИОД И РОУТЕР" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="0,0,0,8">
                    <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,6,8" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker x:Name="DpFrom" Width="130" Margin="0,0,16,8"/>
                    <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,6,8" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <DatePicker x:Name="DpTo" Width="130" Margin="0,0,16,8"/>
                    <CheckBox x:Name="ChkShowSecrets" Style="{StaticResource CompactCheckBox}"
                              Content="Показать пароли Wi‑Fi" IsChecked="True" Margin="0,0,16,8"/>
                    <CheckBox x:Name="ChkSimulate" Style="{StaticResource CompactCheckBox}"
                              Content="Только показать (не удалять)" Margin="0,0,0,8"/>
                </WrapPanel>
                <WrapPanel>
                    <TextBlock Text="Роутер IP:" VerticalAlignment="Center" Margin="0,0,6,8"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtRouterIp" Width="120" Margin="0,0,12,8" Padding="6,4"
                             ToolTip="Пусто = шлюз по умолчанию"/>
                    <TextBlock Text="Логин:" VerticalAlignment="Center" Margin="0,0,6,8"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox x:Name="TxtRouterLogin" Width="100" Margin="0,0,12,8" Padding="6,4"/>
                    <TextBlock Text="Пароль:" VerticalAlignment="Center" Margin="0,0,6,8"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <PasswordBox x:Name="TxtRouterPassword" Width="120" Margin="0,0,0,8" Padding="6,4"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <CheckBox x:Name="ChkWiFi" Style="{StaticResource CompactCheckBox}" Content="Wi‑Fi" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkEthernet" Style="{StaticResource CompactCheckBox}" Content="Ethernet" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkVpn" Style="{StaticResource CompactCheckBox}" Content="VPN" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkRouter" Style="{StaticResource CompactCheckBox}" Content="Роутер" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkDns" Style="{StaticResource CompactCheckBox}" Content="DNS" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkLogs" Style="{StaticResource CompactCheckBox}" Content="Журналы" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkRegistry" Style="{StaticResource CompactCheckBox}" Content="Реестр" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkCache" Style="{StaticResource CompactCheckBox}" Content="Кэши" IsChecked="True" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkUsbBt" Style="{StaticResource CompactCheckBox}" Content="USB/BT" IsChecked="True"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource MainCard}" MinHeight="260">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#F9FAFB" BorderBrush="{StaticResource BorderBrushModern}"
                        BorderThickness="0,0,0,1" Padding="14,10">
                    <TextBlock x:Name="TxtNetworkCount" Text="Найдено: 0"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>
                <DataGrid x:Name="GridNetwork" Grid.Row="1" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          GridLinesVisibility="All">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding DisplayTime}" IsReadOnly="True" Width="130"/>
                        <DataGridTextColumn Header="Раздел" Binding="{Binding DisplayGroup}" IsReadOnly="True" Width="90"/>
                        <DataGridTextColumn Header="Источник" Binding="{Binding Source}" IsReadOnly="True" Width="120"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Title}" IsReadOnly="True" Width="220"/>
                        <DataGridTextColumn Header="Детали" Binding="{Binding DisplayDetail}" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="TxtNetworkPhase" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <ProgressBar x:Name="ProgressNetwork" Height="5" Minimum="0" Maximum="100" Background="#E5E7EB"
                         Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <Border Grid.Row="4" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1"
                CornerRadius="12" Margin="0,10,0,0" Padding="0">
            <TextBox x:Name="TxtNetworkLog" Background="Transparent" Foreground="#E5E7EB"
                     FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0" Padding="12,10"/>
        </Border>

        <Border Grid.Row="5" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushModern}"
                BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnNetSelectAll" Content="Выбрать все" Style="{StaticResource SecondaryButton}"
                        MinWidth="108" Margin="0,0,8,0" Click="BtnNetSelectAll_Click"/>
                <Button x:Name="BtnNetDeselectAll" Content="Снять все" Style="{StaticResource SecondaryButton}"
                        MinWidth="108" Margin="0,0,8,0" Click="BtnNetDeselectAll_Click"/>
                <Button x:Name="BtnNetScan" Content="Сканировать" Style="{StaticResource PrimaryButton}"
                        MinWidth="124" Margin="0,0,8,0" Click="BtnNetScan_Click"/>
                <Button x:Name="BtnNetClean" Content="Очистить следы" Style="{StaticResource DangerButton}"
                        MinWidth="140" Click="BtnNetClean_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
