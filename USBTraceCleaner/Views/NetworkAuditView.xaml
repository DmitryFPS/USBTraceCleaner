<UserControl x:Class="USBTraceCleaner.Views.NetworkAuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock x:Name="TxtNetworkPhase" Text="" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="0,0,0,4"/>
            <ProgressBar x:Name="ProgressNetwork" Height="4" Minimum="0" Maximum="100"
                         Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="0"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Аудит сети" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Проверка подключений и максимальная очистка следов на ПК"
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource MainCard}" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock Text="РАЗРЕШЁННЫЕ ПОДКЛЮЧЕНИЯ (БЕЛЫЙ СПИСОК)" Style="{StaticResource SectionHeader}"/>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtAllowedIps" Width="220" Margin="0,0,14,8" Padding="6,4"
                                 Text="20.0.0.116, 20.20.20.76"/>
                        <TextBlock Text="Wi‑Fi:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtAllowedWiFi" Width="100" Margin="0,0,14,8" Padding="6,4"
                                 Text="doZOR"/>
                        <TextBlock Text="VPN:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtAllowedVpn" Width="160" Margin="0,0,0,8" Padding="6,4"
                                 Text="HAPP, happ, happ-tun"/>
                    </WrapPanel>
                    <CheckBox x:Name="ChkShowUnknownOnly" Style="{StaticResource CompactCheckBox}"
                              Content="Показать только неизвестные (не из белого списка)" Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource MainCard}" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock Text="ПЕРИОД, СКАН И ОЧИСТКА" Style="{StaticResource SectionHeader}"/>
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock Text="С:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker x:Name="DpFrom" Width="128" Margin="0,0,14,8"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker x:Name="DpTo" Width="128" Margin="0,0,14,8"/>
                        <CheckBox x:Name="ChkShowSecrets" Style="{StaticResource CompactCheckBox}"
                                  Content="Показать пароли Wi‑Fi" IsChecked="True" Margin="0,0,14,8"/>
                        <CheckBox x:Name="ChkSimulation" Style="{StaticResource CompactCheckBox}"
                                  Content="Симуляция (без удаления)" IsChecked="False" Margin="0,0,14,8"
                                  ToolTip="Прогон очистки сети без удаления профилей и журналов"/>
                        <CheckBox x:Name="ChkFullClean" Style="{StaticResource CompactCheckBox}"
                                  Content="Максимальная очистка" IsChecked="True" Margin="0,0,14,8"/>
                        <CheckBox x:Name="ChkDisconnect" Style="{StaticResource CompactCheckBox}"
                                  Content="Отключить сеть после" IsChecked="True" Margin="0,0,14,8"/>
                        <CheckBox x:Name="ChkReboot" Style="{StaticResource CompactCheckBox}"
                                  Content="Перезагрузка после" IsChecked="True" Margin="0,0,0,8"/>
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="Роутер IP:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtRouterIp" Width="110" Margin="0,0,10,8" Padding="6,4"/>
                        <TextBlock Text="Логин:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="TxtRouterLogin" Width="90" Margin="0,0,10,8" Padding="6,4"/>
                        <TextBlock Text="Пароль:" VerticalAlignment="Center" Margin="0,0,6,8"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <PasswordBox x:Name="TxtRouterPassword" Width="110" Margin="0,0,0,8" Padding="6,4"/>
                    </WrapPanel>
                    <WrapPanel>
                        <CheckBox x:Name="ChkWiFi" Style="{StaticResource CompactCheckBox}" Content="Wi‑Fi" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkEthernet" Style="{StaticResource CompactCheckBox}" Content="Ethernet" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkVpn" Style="{StaticResource CompactCheckBox}" Content="VPN" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkRouter" Style="{StaticResource CompactCheckBox}" Content="Роутер" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkDns" Style="{StaticResource CompactCheckBox}" Content="DNS" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkLogs" Style="{StaticResource CompactCheckBox}" Content="Журналы" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkRegistry" Style="{StaticResource CompactCheckBox}" Content="Реестр" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkCache" Style="{StaticResource CompactCheckBox}" Content="Кэши" IsChecked="True" Margin="0,0,10,0"/>
                        <CheckBox x:Name="ChkUsbBt" Style="{StaticResource CompactCheckBox}" Content="USB/BT" IsChecked="True" Margin="0,0,0,0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border x:Name="NetworkResultsHost" Grid.Row="3" Style="{StaticResource MainCard}" MinHeight="180">
                <Grid x:Name="NetworkResultsGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="0"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushModern}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <TextBlock x:Name="TxtNetworkCount" Text="Найдено: 0" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                    <DataGrid x:Name="GridNetwork" Grid.Row="1"
                              Style="{StaticResource ResultsDataGrid}"
                              CellStyle="{StaticResource ResultsDataGridCell}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Extended"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="44" MinWidth="44" CanUserResize="False"
                                                    CellStyle="{StaticResource ResultsDataGridCheckCell}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource GridCheckBox}"
                                                  IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding CanClean}"
                                                  ToolTip="Только строки, которые можно очистить, доступны для отметки"
                                                  Click="NetworkCheck_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Разрешено?" Binding="{Binding DisplayAuthorization}" IsReadOnly="True" Width="110" MinWidth="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AuthorizationStatus}" Value="Unknown">
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DisplayTime}" IsReadOnly="True" Width="140" MinWidth="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Раздел" Binding="{Binding DisplayGroup}" IsReadOnly="True" Width="100" MinWidth="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Тип" Binding="{Binding ActionLabel}" IsReadOnly="True" Width="90" MinWidth="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Title}" IsReadOnly="True" Width="280" MinWidth="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="При очистке" Binding="{Binding CleanEffect}" IsReadOnly="True" Width="260" MinWidth="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <!-- Same idea as «Путь в реестре» in Other USB: wide fixed column → H-scroll -->
                            <DataGridTextColumn Header="Детали" Binding="{Binding DisplayDetail}" IsReadOnly="True" Width="200" MinWidth="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
