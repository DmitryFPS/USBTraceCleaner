<UserControl x:Class="USBTraceCleaner.Views.EventLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:USBTraceCleaner.Controls"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="EventChannelCellText" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EventChannelCell" TargetType="DataGridCell" BasedOn="{StaticResource ResultsDataGridCell}">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EventLogsDataGrid" TargetType="DataGrid" BasedOn="{StaticResource ResultsDataGrid}">
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Item"/>
            <Setter Property="controls:DataGridScrollHelper.FillAndScroll" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <!-- Уровень 1: Группа (Microsoft, Журналы Windows…) -->
        <GroupStyle x:Key="EventGroupStyle">
            <GroupStyle.ContainerStyle>
                <Style TargetType="{x:Type GroupItem}">
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="8,6" Margin="4,2">
                                    <Expander IsExpanded="False" Background="Transparent" BorderThickness="0"
                                              Foreground="{StaticResource TextPrimaryBrush}">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="{Binding ItemCount, StringFormat={}{0} журн.}"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ItemsPresenter Margin="8,6,0,0"/>
                                    </Expander>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GroupStyle.ContainerStyle>
        </GroupStyle>

        <!-- Уровень 2: Канал-семейство (Microsoft-Windows-Kernel-PnP/…) -->
        <GroupStyle x:Key="EventChannelFamilyStyle">
            <GroupStyle.ContainerStyle>
                <Style TargetType="{x:Type GroupItem}">
                    <Setter Property="Margin" Value="12,0,0,2"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0"
                                          Padding="0,2" Foreground="{StaticResource TextPrimaryBrush}">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding ItemCount, StringFormat={}{0} зап.}"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <ItemsPresenter Margin="16,4,0,2"/>
                                </Expander>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GroupStyle.ContainerStyle>
        </GroupStyle>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock x:Name="TxtPhase" Text="" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="0,0,0,4"/>
            <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100"
                         Background="#E2E8F0" Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="0"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Журналы событий" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Группы и каналы сворачиваются как в Event Viewer. Двойной клик / «События» — записи журнала."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource MainCard}" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               Margin="0,0,0,8">
                        Список с этого ПК. Сверху — группа, внутри — канал (семейство), затем строки.
                        «Выбрать все» отмечает видимую группу. Безопасность — только с галочкой ниже.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkIncludeSecurity" Style="{StaticResource CompactCheckBox}"
                                  Content="Включать журнал «Безопасность» в очистку" IsChecked="False"
                                  Margin="0,0,20,0"/>
                        <CheckBox x:Name="ChkClearSystemLast" Style="{StaticResource CompactCheckBox}"
                                  Content="В конце очистить «Система» (Event ID 104)" IsChecked="True"
                                  ToolTip="После очистки других журналов Windows пишет Event ID 104 в «Система». Повторная очистка System в самом конце убирает эти записи."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="EventResultsHost" Grid.Row="2" Style="{StaticResource MainCard}" MinHeight="180">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="0"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrushModern}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <TextBlock x:Name="TxtChannelCount" Text="Найдено: 0" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                    <DataGrid x:Name="GridChannels" Grid.Row="1"
                              Style="{StaticResource EventLogsDataGrid}"
                              CellStyle="{StaticResource EventChannelCell}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              MouseDoubleClick="GridChannels_MouseDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                        <DataGrid.GroupStyle>
                            <StaticResource ResourceKey="EventGroupStyle"/>
                            <StaticResource ResourceKey="EventChannelFamilyStyle"/>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="44" MinWidth="44" CanUserResize="False"
                                                    CellStyle="{StaticResource ResultsDataGridCheckCell}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource GridCheckBox}"
                                                  IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Click="ChannelCheck_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Канал" Binding="{Binding DisplayName}" IsReadOnly="True"
                                                Width="180" MinWidth="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventChannelCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Записей" Binding="{Binding DisplayCount}" IsReadOnly="True"
                                                Width="90" MinWidth="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventChannelCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Размер" Binding="{Binding DisplaySize}" IsReadOnly="True"
                                                Width="80" MinWidth="64">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventChannelCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Изменён" Binding="{Binding DisplayLastWrite}" IsReadOnly="True"
                                                Width="140" MinWidth="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventChannelCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn x:Name="ColWindowsName" Header="Имя в Windows"
                                                Binding="{Binding Channel}" IsReadOnly="True"
                                                Width="280" MinWidth="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource EventChannelCellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
