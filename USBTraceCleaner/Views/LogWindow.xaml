<Window x:Class="USBTraceCleaner.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал"
        Width="680" Height="440"
        MinWidth="480" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Копировать" Style="{StaticResource SecondaryButton}"
                    MinWidth="110" Margin="0,0,8,0" Click="BtnCopy_Click"/>
            <Button Content="Закрыть" Style="{StaticResource PrimaryButton}"
                    MinWidth="110" IsDefault="True" Click="BtnClose_Click"/>
        </StackPanel>
        <Border Style="{StaticResource MainCard}">
            <TextBox x:Name="TxtLogContent"
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0" Padding="12"/>
        </Border>
    </DockPanel>
</Window>
